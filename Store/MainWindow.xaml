<Window x:Class="Store.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Store"
        mc:Ignorable="d"
        Title="Store" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

	<Window.Resources>
		<Style x:Key="ProductCardStyle" TargetType="Button">
			<Setter Property="Background" Value="#FFFFFF"/>
			<Setter Property="BorderBrush" Value="#E9ECEF"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Width" Value="165"/>
			<Setter Property="Height" Value="215"/>
			<Setter Property="Margin" Value="8"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
							<Border.Effect>
								<DropShadowEffect Color="#000000" Opacity="0.05"
                                                  BlurRadius="8" ShadowDepth="2"/>
							</Border.Effect>
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="135"/>
									<RowDefinition Height="*"/>
								</Grid.RowDefinitions>
								<Border Grid.Row="0" Background="#E9ECEF"
                                        CornerRadius="7,7,0,0" ClipToBounds="True">
									<Image Source="/Images/placeholder.png"
									Stretch="UniformToFill"/>
								</Border>
								<StackPanel Grid.Row="1"
									VerticalAlignment="Center">
									<TextBlock Text="{Binding Name}" FontSize="12"
                                               Foreground="#212529" FontWeight="Medium"
                                               TextTrimming="CharacterEllipsis"/>
									<TextBlock Text="{Binding Price, StringFormat={}{0:N2} &#x20BD;}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="#495057" Margin="0,4,0,0"/>
								</StackPanel>
							</Grid>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#F8F9FA"/>
								<Setter Property="BorderBrush" Value="#ADB5BD"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>


		<Style x:Key="AdminButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="#495057"/>
			<Setter Property="Padding" Value="6,0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Foreground" Value="#212529"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Grid Background="#F8F9FA">
		<Grid.RowDefinitions>
			<RowDefinition Height="56"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Border Grid.Row="0" Background="#FFFFFF"
                BorderBrush="#E9ECEF" BorderThickness="0,0,0,1">
			<Grid>
				<StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
					<Border BorderBrush="#CED4DA" BorderThickness="1"
                            CornerRadius="16" Height="34" Width="190"
                            Background="#FFFFFF">
						<Grid>
							<TextBlock Text="Поиск.." Foreground="#ADB5BD"
                                       VerticalAlignment="Center" Margin="14,0,0,0"
                                       FontSize="12" IsHitTestVisible="False">
								<TextBlock.Style>
									<Style TargetType="TextBlock">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                                                         Value="">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>
							<TextBox x:Name="SearchBox"
                                     Background="Transparent" BorderThickness="0"
                                     VerticalAlignment="Center"
                                     Margin="14,0,32,0" FontSize="12"
                                     TextChanged="SearchBox_TextChanged"/>
							
						</Grid>
					</Border>
				</StackPanel>

				<StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">

					<Button x:Name="AdminAddButton"
                            Content="ADD"
                            Style="{StaticResource AdminButtonStyle}"
                            Margin="0,0,16,0"
                            Visibility="Collapsed"
                            Click="AdminAddButton_Click"/>

					<Button x:Name="AdminDeleteButton"
                            Content="DELETE"
                            Style="{StaticResource AdminButtonStyle}"
                            Margin="0,0,16,0"
                            Visibility="Collapsed"
                            Click="AdminDeleteButton_Click"/>

					<Rectangle x:Name="AdminSeparator"
                               Width="1" Height="20" Fill="#E9ECEF"
                               Margin="0,0,16,0"
                               Visibility="Collapsed"/>

					<ComboBox x:Name="CategoriesComboBox"
                              Width="145" Height="32"
                              Margin="0,0,12,0"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              FontSize="12"
                              Background="#FFFFFF"
                              BorderBrush="#CED4DA"
                              SelectionChanged="CategoriesComboBox_SelectionChanged"/>
		<!--   -->
					<Button x:Name="NewButton" Height="32" Padding="14,0"
                            FontSize="12" FontWeight="Medium"
                            Foreground="#FFFFFF" Background="#212529"
                            BorderThickness="0" Cursor="Hand"
                            Click="NewFilterButton_Click">
						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
									<ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter Property="Background" Value="#343A40"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Button.Template>
						<StackPanel Orientation="Horizontal">

							<TextBlock Text="New"/>
						</StackPanel>
					</Button>

				</StackPanel>

			</Grid>
		</Border>

		<ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="8,8,8,16">
			<StackPanel>

				<ItemsControl x:Name="ProductsItemsControl">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel Orientation="Horizontal"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button Style="{StaticResource ProductCardStyle}"
                                    Tag="{Binding Id}"
                                    Click="ProductCardButton_Click"/>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<Button x:Name="PromoCard"
                        Margin="8,4,8,8"
                        Background="#FFFFFF"
                        BorderBrush="#E9ECEF"
                        BorderThickness="1"
                        Height="240"
                        Cursor="Hand"
                        Click="ProductCardButton_Click"
                        Tag="0">
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
								<Border.Effect>
									<DropShadowEffect Color="#000000" Opacity="0.05"
                                                      BlurRadius="8" ShadowDepth="2"/>
								</Border.Effect>
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition Height="180"/>
										<RowDefinition Height="*"/>
									</Grid.RowDefinitions>
									<Border Grid.Row="0" Background="#E9ECEF"
                                            CornerRadius="7,7,0,0" ClipToBounds="True">
										<Image x:Name="PromoImage" Stretch="UniformToFill"/>
									</Border>
									<StackPanel Grid.Row="1">
										<TextBlock x:Name="PromoName"
                                                   Text="Акционное предложение"
                                                   FontSize="14" Foreground="#212529"
                                                   FontWeight="SemiBold"/>
										<TextBlock Text="0.00 &#x20BD;"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#495057" Margin="0,3,0,0"/>
									</StackPanel>
								</Grid>
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter Property="Background" Value="#F8F9FA"/>
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Button.Template>
				</Button>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</Window>
