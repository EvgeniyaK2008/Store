<Window x:Class="Store.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="320" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
	<Grid Background="#F0F2F5" Margin="0,-136,-255,-206">
		<Border Background="White" CornerRadius="12"
                Margin="30,126,291,184" Padding="30" RenderTransformOrigin="0.5,0.5">
			<Border.RenderTransform>
				<TransformGroup>
					<ScaleTransform/>
					<SkewTransform AngleX="-0.171"/>
					<RotateTransform/>
					<TranslateTransform X="-0.364"/>
				</TransformGroup>
			</Border.RenderTransform>
			<StackPanel VerticalAlignment="Center">

				<TextBlock Text="Store" FontSize="24" FontWeight="Bold"
                           Foreground="#5B6AF0" HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
				<TextBlock Text="Войдите в аккаунт" FontSize="12"
                           Foreground="#6B7280" HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

				<TextBlock Text="Имя пользователя" FontSize="12"
                           Foreground="#6B7280" Margin="0,0,0,4"/>
				<TextBox x:Name="UsernameBox" Height="34" Padding="10,0"
                         FontSize="13" BorderBrush="#CED4DA"
                         Margin="0,0,0,12"/>

				<TextBlock Text="Пароль" FontSize="12"
                           Foreground="#6B7280" Margin="0,0,0,4"/>
				<PasswordBox x:Name="PasswordBox" Height="34" Padding="10,0"
                             FontSize="13" BorderBrush="#CED4DA"
                             Margin="0,0,0,20"/>

				<Button Content="Войти" Height="32" FontSize="13"
                        FontWeight="SemiBold" Background="#5B6AF0"
                        Foreground="White" BorderThickness="0"
                        Click="Login_Click">
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border Background="{TemplateBinding Background}"
                                    CornerRadius="6">
								<ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
							</Border>
						</ControlTemplate>
					</Button.Template>
				</Button>

				<TextBlock x:Name="ErrorText" Text="" Foreground="#E05C5C"
                           FontSize="11" HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>
